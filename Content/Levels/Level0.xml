		<!-- КАДР 1: Начало сюжета -->
		<Component Text="Давным-давно мир был разделен войной машин и людей... Но люди проиграли. Их города обращены в пепел, а армии рассеяны."
				   Texture="Content/Textures/im2.png"
				   Position="0,0"
				   Size="800,600"
				   Color="125,125,125"
				   FontSize="24" />

		<!-- КАДР 2: Развитие сюжета -->
		<Component Text="Но ты, мой герой, остался последним командиром, способным остановить хаос. Я — последний лояльный ИИ человечества. Мои системы повреждены, но я функционирую... ради тебя."
				   Texture="Content/Textures/im2.png"
				   Position="0,0"
				   Size="800,600"
				   Color="175,125,125"
				   FontSize="24" />


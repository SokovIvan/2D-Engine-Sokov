<?xml version="1.0" encoding="utf-8" ?>
<Level Name="Forest_1" Width="1920" Height="1080">
	<!-- Фоновые элементы -->
	<Background>
		<Layer Texture="bg_sky.png" ScrollFactor="0.2"/>
		<Layer Texture="bg_mountains.png" ScrollFactor="0.5"/>
	</Background>

	<!-- Игровые объекты -->
	<Objects>
		<Player X="300" Y="500" Width="80" Height="120"
				Texture="player.png" Collision="true"
				Animation="idle" Health="100"/>

		<Sprite Type="Tree" X="700" Y="520" Width="100" Height="180"
				Texture="tree_oak.png" Collision="true" Rotation="0"/>

	</Objects>

	<!-- Пользовательский интерфейс -->
	<UI>
		<Element Type="HealthBar" X="20" Y="20" Width="200" Height="30"
				 Texture="ui/health_bg.png" Foreground="ui/health_fg.png"/>

		<Element Type="Button" X="50" Y="980" Width="120" Height="50"
				 Texture="ui/btn_menu.png" Text="Menu"
				 OnClick="OpenMainMenu" Font="Arial" FontSize="14"/>

		<Element Type="Label" X="1800" Y="20" Width="100" Height="40"
				 Text="Score: 0" Font="Arial" FontSize="24" Align="Right"/>
	</UI>

	<!-- Системные параметры -->
	<Physics Gravity="0.5" />
</Level>